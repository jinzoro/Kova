# ── News (required for /news page) ───────────────────────────────────────────
# Server-side only — no NEXT_PUBLIC_ prefix needed.
# Free key at https://min-api.cryptocompare.com
NEWS_API_KEY=your_cryptocompare_api_key_here

# ── CoinMarketCap (optional fallback for rare coins) ──────────────────────────
# Server-side only — never exposed to the browser.
# Free "Basic" plan at https://coinmarketcap.com/api/
CMC_API_KEY=your_cmc_api_key_here

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
